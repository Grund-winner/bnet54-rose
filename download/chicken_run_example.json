    "html": "<html lang=\"en\"><head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Chicken Road Signal Game</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&amp;family=Rajdhani:wght@300;400;500;600;700&amp;display=swap\" rel=\"stylesheet\">\n    <link rel=\"stylesheet\" href=\"styles.css\">\n</head>\n<body>\n    <!-- Additional atmospheric elements -->\n    <div class=\"atmospheric-decor\"></div>\n    <div class=\"atmospheric-decor\"></div>\n    <div class=\"atmospheric-decor\"></div>\n    <div class=\"atmospheric-decor\"></div>\n    \n    <div class=\"game-container\">\n        <!-- Logo -->\n        <div class=\"logo-container\">\n            <img src=\"logo.png\" alt=\"Chicken Road\" class=\"logo\" onerror=\"this.style.display='none'\" style=\"display: none;\">\n        </div>\n        \n        <!-- Game Mode Selector -->\n        <div class=\"game-mode-selector\">\n            <div class=\"mode-title\">Choose Game Mode</div>\n            <div class=\"mode-buttons\">\n                <button class=\"mode-btn active\" data-mode=\"easy\">Easy</button>\n                <button class=\"mode-btn\" data-mode=\"medium\">Medium</button>\n                <button class=\"mode-btn\" data-mode=\"hard\">Hard</button>\n                <button class=\"mode-btn\" data-mode=\"hardcore\">Hardcore</button>\n            </div>\n        </div>\n        \n        <div class=\"tunnel\">\n            <div class=\"tunnel-decoration\"></div>\n            <div class=\"tunnel-decoration\"></div>\n            \n            <!-- Beautiful castle decorations -->\n            <div class=\"castle-decoration-left\"></div>\n            <div class=\"castle-decoration-right\"></div>\n            <div class=\"castle-decoration-mid-left\"></div>\n            <div class=\"castle-decoration-mid-right\"></div>\n            \n            <!-- Mystical glowing points -->\n            <div class=\"mystical-light-1\"></div>\n            <div class=\"mystical-light-2\"></div>\n            <div class=\"mystical-light-3\"></div>\n            <div class=\"mystical-light-4\"></div>\n            <div class=\"mystical-light-5\"></div>\n            \n            <!-- Дополнительные замковые детали -->\n            <div class=\"castle-chain-left\"></div>\n            <div class=\"castle-chain-right\"></div>\n            \n            <!-- Beautiful background behind chicken -->\n            <div class=\"chicken-background\"></div>\n            \n          \n            \n            <div class=\"chicken\" id=\"chicken\" style=\"display: block;\">\n                <img src=\"chick.png\" alt=\"Chicken\" id=\"chicken-img\">\n            </div>\n            \n            <!-- Анимация огня -->\n            \n            \n            <!-- Мертвая курица с множителем -->\n            \n        </div>\n        \n        <div class=\"signal-button-container\">\n            <button class=\"get-signal-btn\" id=\"getSignalBtn\">Get Signal</button>\n        </div>\n        \n                 <!-- Back and Telegram Buttons -->\n         <div class=\"bottom-buttons-container\">\n             <button class=\"back-btn\" id=\"backBtn\">\n                 <div class=\"back-icon\">←</div>\n                 <span class=\"back-text\">Back</span>\n             </button>\n             \n             <!--<button class=\"telegram-btn\" onclick=\"window.open('https://t.me/minesprosignal_bot', '_blank')\">\n                 <div class=\"telegram-icon\">\n                     <div class=\"telegram-logo\"></div>\n                 </div>\n                 <span class=\"telegram-text\">@minesprosignal_bot</span>\n             </button>-->\n         </div>\n    </div>\n    \n    <script src=\"script.js\"></script>\n<script src=\"../../protect.js\"></script>\n\n </body></html>",
